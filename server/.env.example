# Server configuration keys
SERVER_PORT=3000
SERVER_URL=http://localhost:3000
CLIENT_ORIGINS=http://localhost:5173

# Database configuration keys
DATABASE_URL=postgresql://user:password@host:5432/database


# JWT configuration keys
JWT_SECRET=your-key

# Redis configuration keys
REDIS_HOST=your-key
REDIS_PORT=6379
REDIS_PASSWORD=your-key

# Gmail API keys
GOOGLE_CLIENT_ID=your-key
GOOGLE_CLIENT_SECRET=your-key
GOOGLE_REFRESH_TOKEN=your-key
GOOGLE_SENDER_EMAIL=your-email@example.com

# Mailjet keys
MJ_APIKEY_PUBLIC=your-key
MJ_APIKEY_PRIVATE=your-key
MJ_USER=your-email@example.com


# ImageKit keys
IMAGEKIT_PRIVATE_KEY=your-key